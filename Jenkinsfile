    agent any

    stages {
        stage('Clone') {
            steps {
                echo 'Code cloned successfully'
            }
        }

        stage('Build') {
            steps {
                echo 'Building HTML project...'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing project...'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deployment successful 🚀'
            }
        }
    }
}
